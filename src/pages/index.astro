---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
// Sort by date descending
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Extract unique categories
const allCategories = ['সব', ...new Set(posts.flatMap(post => post.data.categories))];

// Bengali Date Formatter
const formatDate = (date: Date) => {
	return new Intl.DateTimeFormat('bn-BD', {
		day: 'numeric',
		month: 'long',
		year: 'numeric'
	}).format(date);
};
---

<Layout title="চিন্তা, বিশ্বাস ও কর্ম | Mohammad Abdul Haque">
	
	<!-- Hero Section -->
	<div class="text-center max-w-2xl mx-auto mb-12">
		<h2 class="text-amber-600 text-sm font-semibold mb-2">ব্যক্তিগত জার্নাল</h2>
		<h1 class="text-4xl md:text-5xl font-bold text-white mb-6">চিন্তা, বিশ্বাস ও কর্ম</h1>
		<p class="text-gray-400 leading-relaxed">
			আসসালামু আলাইকুম। আমি মোহাম্মদ আবদুল হক। এখানে বাংলা, আরবি ও মাঝেমাঝে ইংরেজিতে লিখি—যা ভাবি, যা পড়ি, যা শিখি।
		</p>
		<div class="w-16 h-px bg-gray-700 mx-auto mt-6"></div>
	</div>

	<!-- Search Bar -->
	<div class="max-w-xl mx-auto mb-6 relative">
		<svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
		</svg>
		<input 
			type="text" 
			placeholder="লেখা খুঁজুন—শিরোনাম বা ভেতরের যেকোনো শব্দ..." 
			class="w-full bg-[#1c1c1c] border border-gray-800 text-white rounded-full py-3 pl-12 pr-4 focus:outline-none focus:border-amber-500 transition-colors placeholder-gray-600"
		/>
	</div>

	<!-- Category Pills -->
	<div class="flex flex-wrap justify-center gap-3 mb-8 max-w-3xl mx-auto">
		{allCategories.map((cat, index) => (
			<button class={`px-4 py-1.5 rounded-full text-sm border transition-colors ${
				index === 0 
				? 'bg-amber-600 text-white border-amber-600' 
				: 'bg-[#1c1c1c] text-gray-400 border-gray-800 hover:border-gray-600'
			}`}>
				{cat}
			</button>
		))}
	</div>

	<!-- View Toggle Controls -->
	<div class="flex justify-end mb-6 border-b border-gray-800 pb-4">
		<button id="view-toggle-btn" class="flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
			<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
			</svg>
			<span>ভিউ পরিবর্তন করুন</span>
		</button>
	</div>

	<!-- VIEW A: List View -->
	<div id="list-view" class="max-w-3xl mx-auto space-y-10 block">
		{posts.map((post) => (
			<article class="border-b border-gray-800 pb-8 last:border-0">
				<div class="flex items-center gap-3 text-xs mb-3">
					{post.data.categories.map(cat => (
						<span class="px-2 py-1 rounded-full border border-amber-700/50 text-amber-500">{cat}</span>
					))}
					<span class="text-gray-500">{formatDate(post.data.date)}</span>
				</div>
				<a href={`/blog/${post.slug}`}>
					<h3 class="text-2xl font-bold text-white mb-3 hover:text-amber-500 transition-colors">{post.data.title}</h3>
				</a>
				<p class="text-gray-400 mb-4 line-clamp-2 leading-relaxed">{post.data.excerpt}</p>
				<a href={`/blog/${post.slug}`} class="text-amber-600 text-sm hover:text-amber-500 flex items-center gap-1">
					পড়ুন <span class="text-lg">→</span>
				</a>
			</article>
		))}
	</div>

	<!-- VIEW B: Gallery View -->
	<div id="gallery-view" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 hidden">
		{posts.map((post) => (
			<a href={`/blog/${post.slug}`} class="block group">
				<div class="bg-[#1c1c1c] rounded-xl overflow-hidden border border-gray-800 hover:border-gray-600 transition-colors h-full flex flex-col">
					<div class="p-5 flex-grow">
						<p class="text-gray-300 text-sm leading-relaxed line-clamp-6">{post.data.excerpt}</p>
					</div>
					<div class="px-5 py-3 border-t border-gray-800 bg-[#161616] flex items-center gap-2">
						<svg class="w-4 h-4 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
						</svg>
						<span class="text-xs font-medium text-gray-400 truncate group-hover:text-amber-500 transition-colors">{post.data.title}</span>
					</div>
				</div>
			</a>
		))}
	</div>

</Layout>

<script>
	// Vanilla JS View Toggle Logic
	const toggleBtn = document.getElementById('view-toggle-btn');
	const listView = document.getElementById('list-view');
	const galleryView = document.getElementById('gallery-view');

	if (toggleBtn && listView && galleryView) {
		toggleBtn.addEventListener('click', () => {
			listView.classList.toggle('hidden');
			galleryView.classList.toggle('hidden');
		});
	}
</script>
