---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'চিন্তা, বিশ্বাস ও কর্ম — Mohammad Abdul Haque',
  description = 'আসসালামু আলাইকুম।  আমি মাহমুদ হৃদয়। এখানে আমি লিখি — যা ভাবি, যা পড়ি, যা শিখি।',
} = Astro.props;
---

<!doctype html>
<html lang="bn">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        if (saved === 'light') {
          document.documentElement.classList.add('light');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-bengali">
    <header class="border-b border-linec">
      <div class="max-w-5xl mx-auto flex items-center justify-between px-5 py-5">
        <a href="/" class="font-serifBengali text-lg font-semibold text-paper">
          Mohammad Abdul Haque.
        </a>
        <nav class="flex items-center gap-6 text-sm">
          <a href="/#posts" class="hover:text-gold transition-colors">লেখা</a>
          <a href="/about" class="hover:text-gold transition-colors">পরিচিতি</a>
          <button
            id="theme-toggle"
            aria-label="থিম পরিবর্তন করুন"
            class="w-8 h-8 flex items-center justify-center rounded-full border border-linec hover:border-gold transition-colors"
          >
            <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-4 h-4">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
            </svg>
            <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-4 h-4 hidden">
              <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"></path>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-linec mt-16">
      <div class="max-w-5xl mx-auto px-5 py-8 text-sm text-muted text-center">
        © {new Date().getFullYear()} Mahmud Hridoy. সর্বস্বত্ব সংরক্ষিত।
      </div>
    </footer>

    <script is:inline>
      const btn = document.getElementById('theme-toggle');
      const sun = document.getElementById('icon-sun');
      const moon = document.getElementById('icon-moon');

      function syncIcons() {
        const isLight = document.documentElement.classList.contains('light');
        sun.classList.toggle('hidden', isLight);
        moon.classList.toggle('hidden', !isLight);
      }
      syncIcons();

      btn.addEventListener('click', () => {
        document.documentElement.classList.toggle('light');
        localStorage.setItem(
          'theme',
          document.documentElement.classList.contains('light') ? 'light' : 'dark'
        );
        syncIcons();
      });
    </script>
  </body>
</html>
